<?xml version="1.0" encoding="UTF-8"?>
<!-- DMN 1.3 format — BKM with invocation -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  id="dti_model" name="DTI Calculator" namespace="https://example.com/dti">

  <inputData id="income" name="Monthly Income"/>
  <inputData id="payment" name="Monthly Payment"/>

  <businessKnowledgeModel id="bkm_dti" name="Calculate DTI">
    <variable name="Calculate DTI" typeRef="number"/>
    <encapsulatedLogic id="fd1" kind="FEEL">
      <formalParameter id="fp1" name="monthly income" typeRef="number"/>
      <formalParameter id="fp2" name="monthly payment" typeRef="number"/>
      <literalExpression id="le_body">
        <text>monthly payment / monthly income</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>

  <decision id="dti" name="DTI Ratio">
    <informationRequirement><requiredInput href="#income"/></informationRequirement>
    <informationRequirement><requiredInput href="#payment"/></informationRequirement>
    <knowledgeRequirement><requiredKnowledge href="#bkm_dti"/></knowledgeRequirement>
    <invocation id="inv_dti">
      <literalExpression id="le_callee"><text>Calculate DTI</text></literalExpression>
      <binding id="b1">
        <parameter name="monthly income" typeRef="number"/>
        <literalExpression id="le_b1"><text>Monthly Income</text></literalExpression>
      </binding>
      <binding id="b2">
        <parameter name="monthly payment" typeRef="number"/>
        <literalExpression id="le_b2"><text>Monthly Payment</text></literalExpression>
      </binding>
    </invocation>
  </decision>

</definitions>
